{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BackgroundVerification": {
    "DefaultCheckLevel": "Standard",
    "ReportPath": "Reports"
  },
  "DocumentUpload": {
    "DocumentFolderPath": "Documents",
    "MaxFileSizeInBytes": 10485760
  }
}
